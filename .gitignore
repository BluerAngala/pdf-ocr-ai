venv/
env/
ENV/
.venv
.venv*

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
apps/desktop/dist/
apps/desktop/dist-ssr/
*.local

# =============================================================================
# Rust / Tauri
# =============================================================================
# Cargo build artifacts
target/
Cargo.lock
**/*.rs.bk
*.pdb

# Tauri specific
apps/desktop/src-tauri/target/

# =============================================================================
# IDE / Editors
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.trae/

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# Project specific
# =============================================================================
# Output directories (keep .gitkeep)
output/*
!output/.gitkeep
temp/*
!temp/.gitkeep

# Input test files (large PDFs)
input/**/*.pdf
!input/**/.gitkeep

# Sample materials (large files)
样本材料/**/*.pdf
样本材料/**/*.xlsx

# Temporary files
*.tmp
*.temp
*.log
nul
~$*

# Large archives
*.zip
*.tar.gz
*.rar
*.7z

# Model files (if downloaded locally)
*.onnx
*.pth
*.pkl
*.gguf
models/

# Poppler binaries (too large, users should install separately)
tools/poppler/
*.dll
*.exe
*.lib
*.a
*.so
*.dylib

# PyInstaller
*.spec

# Tauri build resources (auto-synced by build.rs, do not edit manually)
apps/desktop/src-tauri/resources/gjj-ocr-server.exe
apps/desktop/src-tauri/resources/config.yaml
apps/desktop/src-tauri/resources/sample-data/
apps/desktop/src-tauri/resources/server_src/
apps/desktop/src-tauri/resources/poppler/
apps/desktop/src-tauri/resources/sumatrapdf/
!apps/desktop/src-tauri/resources/sumatrapdf/SumatraPDF*.exe
apps/desktop/src-tauri/icons/*.icns

# Repo-level resources/server_src (auto-synced by build.rs from apps/server/src/)
resources/server_src/

# User data (version tracking, caches - only exist at runtime)
.app-version
ocr-gpu-cache.json

# Test scripts (local development)
test_rpc.py
test_server.py
scripts/generate_icons.py

# =============================================================================
# Tauri Signing Keys (NEVER commit private key!)
# =============================================================================
*.key
tauri.key
tauri.key.pub

# =============================================================================
# Keep directory structure
# =============================================================================
!.gitkeep
scripts/
