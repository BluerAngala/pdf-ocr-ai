{
  "name": "gjj-ocr-tools",
  "version": "1.0.0",
  "description": "公积金 OCR 工具 - 桌面版 + 服务端",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run tauri dev --workspace=apps/desktop",
    "desktop:dev": "npm run dev --workspace=apps/desktop",
    "desktop:build": "npm run build --workspace=apps/desktop",
    "desktop:tauri": "npm run tauri --workspace=apps/desktop",
    "lint": "npm run lint --workspace=apps/desktop",
    "lint:fix": "npm run lint:fix --workspace=apps/desktop",
    "format": "npm run format --workspace=apps/desktop",
    "format:check": "npm run format:check --workspace=apps/desktop",
    "test:fix": "python scripts/test_fix.py",
    "test:fix:full": "python scripts/test_fix.py --full",
    "test:fix:skip": "python scripts/test_fix.py --skip-build",
    "test:smart": "python scripts/smart_test.py"
  },
  "devDependencies": {}
}
